# Interactive shell
#

[ -f ~/.custom/colors.sh ]  && . ~/.custom/colors.sh  # always this first
[ -f ~/.custom/shopts.sh ]  && . ~/.custom/shopts.sh
[ -f ~/.custom/alias.sh ]   && . ~/.custom/alias.sh
[ -f ~/.custom/funcs.sh ]   && . ~/.custom/funcs.sh
[ -f ~/.custom/prompt.sh ]  && . ~/.custom/prompt.sh
[ -f ~/.custom/utils.sh ]   && . ~/.custom/utils.sh
