#!/bin/sh
# front-facing theme manager

if [ $# -lt 1 ]; then
  echo 'usage: themectl THEME'        >&2
  echo '       themectl ls'           >&2
  echo 'Changes the current theme'    >&2
  exit 1
fi

XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-"$HOME/.config"}

basedir="$XDG_CONFIG_HOME/themes"
trgdir="$XDG_CONFIG_HOME"
currfile="$basedir/current"

# list all available themes
if [ "$1" = ls ]; then
  current=$(cat "$currfile" 2>/dev/null)
  for f in "$basedir"/*; do
    test ! -d "$f" && continue
    name=$(basename "$f")
    # indicate whether it's the currently in-use theme
    test "$current" = "$name" \
        && printf ' * ' \
        || printf '   '
    echo "$name"
  done
  exit
fi

theme="$1"
srcdir="$basedir/$theme"

# sanity check!
case "$theme" in
  *[!a-zA-Z_-]*)
    echo "error: Special characters are not allowed" >&2
    exit 1
    ;;
esac

if [ ! -d "$srcdir" ]; then
  echo "error: Theme not found: $theme" >&2
  echo 'Type "themectl ls" for a list of available themes.' >&2
  exit 1
fi

echo "applying theme: $theme ..."
echo "$theme" > "$currfile"      # for 'themectl ls'

# helper func: update-file FILE
update-file() {
  echo "copying: $1"
  mkdir -p "$(dirname "$trgdir/$1")"
  cp "$srcdir/$1" "$trgdir/$1"
}

. "$basedir/apply-theme.sh"
